{% extends 'base.html.twig' %}

{% block title %}Débarras Diogène Vitré — Intervention discrète et spécialisée | ClearWay{% endblock %}
{% block meta_description %}Débarras syndrome de Diogène à Vitré. Intervention discrète, équipe formée, désinfection complète. Devis gratuit, sans jugement.{% endblock %}

{% block schema_org %}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Débarras Diogène Vitré",
    "description": "Intervention spécialisée pour les logements touchés par le syndrome de Diogène à Vitré et en Ille-et-Vilaine.",
    "url": "{{ url('services_detail', {slug: 'diogene'}) }}",
    "provider": {
        "@type": "LocalBusiness",
        "name": "ClearWay Débarras",
        "telephone": "+33XXXXXXXXX",
        "email": "contact@clearway.fr"
    },
    "areaServed": {
        "@type": "City",
        "name": "Vitré"
    },
    "serviceType": "Débarras Diogène"
}
</script>
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
        {
            "@type": "Question",
            "name": "Qu'est-ce que le syndrome de Diogène ?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Le syndrome de Diogène est un trouble du comportement caractérisé par une accumulation compulsive d'objets et de déchets, associée à un manque d'hygiène du logement. Il touche principalement les personnes âgées isolées. Une intervention professionnelle est nécessaire pour remettre le logement en état."
            }
        },
        {
            "@type": "Question",
            "name": "L'intervention est-elle discrète ?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Oui, la discrétion est notre priorité. Nous intervenons avec des véhicules banalisés, en horaires adaptés, et nous protégeons les parties communes. Le voisinage n'est pas informé de la nature de l'intervention."
            }
        },
        {
            "@type": "Question",
            "name": "Combien coûte un débarras Diogène ?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Le coût dépend du volume, du niveau d'insalubrité et de la superficie du logement. Comptez entre 1 500 et 5 000 € pour un appartement. Nous établissons un devis précis après visite gratuite."
            }
        },
        {
            "@type": "Question",
            "name": "Travaillez-vous avec les services sociaux ?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Oui, nous pouvons nous coordonner avec les services sociaux, les tuteurs, les CCAS ou les bailleurs sociaux. Nous avons l'habitude de ces situations et savons travailler en équipe avec les différents intervenants."
            }
        }
    ]
}
</script>
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Accueil", "item": "{{ url('accueil') }}"},
        {"@type": "ListItem", "position": 2, "name": "Services", "item": "{{ url('services') }}"},
        {"@type": "ListItem", "position": 3, "name": "Débarras Diogène"}
    ]
}
</script>
{% endblock %}

{% block stylesheets %}
{% include 'services/_landing-styles.html.twig' %}
