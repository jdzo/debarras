<style>
    .lp-hero {
        padding: 48px 0 40px;
        background: linear-gradient(135deg, rgba(234, 88, 12, 0.04) 0%, rgba(234, 88, 12, 0.01) 100%);
        border-bottom: 1px solid rgba(234, 88, 12, 0.08);
    }
    .lp-hero .container { max-width: 800px; margin: 0 auto; padding: 0 24px; }
    .lp-breadcrumb { font-size: 13px; color: var(--muted); margin-bottom: 20px; }
    .lp-breadcrumb a { color: var(--accent); text-decoration: none; }
    .lp-hero h1 {
        font-size: 36px; font-weight: 900; letter-spacing: -1px;
        margin: 0 0 16px; line-height: 1.15;
    }
    .lp-hero h1 span { color: var(--accent); }
    .lp-hero .intro {
        font-size: 17px; color: #374151; line-height: 1.8; margin: 0 0 24px;
    }
    .lp-hero .btn-hero {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 14px 28px; border-radius: var(--radius-full);
        background: var(--text); color: #fff;
        text-decoration: none; font-weight: 700; font-size: 15px;
        transition: all 0.2s;
    }
    .lp-hero .btn-hero:hover { transform: translateY(-1px); box-shadow: 0 8px 24px rgba(0,0,0,0.15); }

    .lp-content { max-width: 800px; margin: 0 auto; padding: 48px 24px; }

    /* Section éditoriale */
    .lp-editorial { margin-bottom: 48px; }
    .lp-editorial h2 {
        font-size: 26px; font-weight: 800; margin: 0 0 16px; letter-spacing: -0.5px;
    }
    .lp-editorial p {
        font-size: 16px; color: #374151; line-height: 1.8; margin: 0 0 16px;
    }
    .lp-editorial p:last-child { margin-bottom: 0; }
    .lp-editorial strong { color: var(--text); }

    .lp-highlight {
        background: var(--card); border-left: 3px solid var(--accent);
        padding: 20px 24px; border-radius: 0 var(--radius) var(--radius) 0;
        margin: 24px 0;
    }
    .lp-highlight p { margin: 0; font-size: 15px; }

    /* Pourquoi un pro */
    .lp-why { margin-bottom: 48px; }
    .lp-why h2 { font-size: 28px; font-weight: 800; margin: 0 0 24px; letter-spacing: -0.5px; }
    .lp-why-grid {
        display: grid; grid-template-columns: 1fr 1fr;
        gap: 16px;
    }
    .lp-why-card {
        background: var(--card); border-radius: var(--radius);
        padding: 24px; border: 1px solid #e4e4e7;
    }
    .lp-why-card .icon { font-size: 28px; margin-bottom: 10px; display: block; }
    .lp-why-card h3 { font-size: 16px; font-weight: 700; margin: 0 0 6px; }
    .lp-why-card p { font-size: 14px; color: var(--muted); margin: 0; line-height: 1.6; }

    /* Checklist */
    .lp-checklist { margin-bottom: 48px; }
    .lp-checklist h2 { font-size: 28px; font-weight: 800; margin: 0 0 20px; letter-spacing: -0.5px; }
    .lp-checklist ul { list-style: none; padding: 0; margin: 0; }
    .lp-checklist li {
        padding: 12px 0; border-bottom: 1px solid #f1f5f9;
        font-size: 15px; display: flex; align-items: center; gap: 10px;
    }
    .lp-checklist li:last-child { border-bottom: none; }
    .lp-checklist li::before {
        content: '✓'; color: var(--accent); font-weight: 700; font-size: 16px; flex-shrink: 0;
    }

    /* FAQ */
    .lp-faq { margin-bottom: 48px; }
    .lp-faq h2 { font-size: 28px; font-weight: 800; margin: 0 0 20px; letter-spacing: -0.5px; }
    .lp-faq details {
        background: var(--card); border: 1px solid #e4e4e7;
        border-radius: var(--radius); margin-bottom: 8px;
        overflow: hidden;
    }
    .lp-faq summary {
        padding: 16px 20px; font-weight: 600; font-size: 15px;
        cursor: pointer; list-style: none; display: flex;
        justify-content: space-between; align-items: center;
    }
    .lp-faq summary::-webkit-details-marker { display: none; }
    .lp-faq summary::after { content: '+'; font-size: 20px; color: var(--accent); font-weight: 700; }
    .lp-faq details[open] summary::after { content: '−'; }
    .lp-faq .faq-answer {
        padding: 0 20px 16px; font-size: 15px; color: #374151; line-height: 1.7;
    }

    /* Témoignage */
    .lp-testimonial {
        background: var(--card); border: 1px solid #e4e4e7;
        border-radius: var(--radius); padding: 28px; margin-bottom: 48px;
    }
    .lp-testimonial .stars { color: var(--accent); font-size: 14px; margin-bottom: 12px; }
    .lp-testimonial .text { font-size: 16px; color: var(--text); line-height: 1.7; margin-bottom: 16px; }
    .lp-testimonial .author {
        font-size: 14px; color: var(--muted); font-weight: 600;
        display: flex; align-items: center; gap: 10px;
    }
    .lp-testimonial .avatar {
        width: 32px; height: 32px; border-radius: 50%;
        background: var(--accent-light); display: flex;
        align-items: center; justify-content: center;
        font-size: 12px; font-weight: 700; color: var(--accent-dark);
    }

    /* CTA */
    .lp-cta {
        background: var(--text); color: #fff; text-align: center;
        padding: 48px 24px; border-radius: 16px; margin-bottom: 48px;
        position: relative; overflow: hidden;
    }
    .lp-cta::before {
        content: ''; position: absolute; top: -40%; right: -10%;
        width: 250px; height: 250px; border-radius: 50%;
        background: rgba(249, 115, 22, 0.08);
    }
    .lp-cta h2 { font-size: 28px; font-weight: 900; margin: 0 0 8px; position: relative; }
    .lp-cta p { color: #a1a1aa; margin: 0 0 24px; font-size: 16px; position: relative; }
    .lp-cta a {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 14px 32px; background: var(--accent); color: #fff;
        border-radius: var(--radius-full); text-decoration: none;
        font-weight: 700; font-size: 15px; position: relative;
        transition: transform 0.2s;
    }
    .lp-cta a:hover { transform: translateY(-2px); }

    /* Autres services */
    .lp-autres { margin-bottom: 32px; }
    .lp-autres h2 { font-size: 20px; font-weight: 700; margin: 0 0 16px; }
    .lp-autres-grid {
        display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 10px;
    }
    .lp-autre-card {
        background: var(--card); border: 1px solid #e4e4e7;
        border-radius: var(--radius); padding: 16px;
        text-decoration: none; color: inherit;
        display: flex; align-items: center; gap: 12px;
        transition: border-color 0.2s;
    }
    .lp-autre-card:hover { border-color: var(--accent); }
    .lp-autre-card .icon { font-size: 24px; }
    .lp-autre-card .name { font-weight: 600; font-size: 14px; }

    @media (max-width: 768px) {
        .lp-hero h1 { font-size: 28px; }
        .lp-why-grid { grid-template-columns: 1fr; }
        .lp-cta { padding: 36px 20px; }
        .lp-cta h2 { font-size: 24px; }
    }
</style>
