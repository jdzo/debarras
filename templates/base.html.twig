<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}ClearWay - Débarras professionnel{% endblock %}</title>
        <meta name="description" content="{% block meta_description %}ClearWay : service professionnel de débarras maison, appartement, succession et Diogène. Estimation gratuite en 2 minutes, intervention rapide.{% endblock %}">
        <link rel="canonical" href="{{ url(app.request.attributes.get('_route'), app.request.attributes.get('_route_params')) }}">
        <meta property="og:title" content="{{ block('title') }}">
        <meta property="og:description" content="{{ block('meta_description') }}">
        <meta property="og:type" content="website">
        <meta property="og:url" content="{{ url(app.request.attributes.get('_route'), app.request.attributes.get('_route_params')) }}">
        <meta property="og:locale" content="fr_FR">
        <meta property="og:site_name" content="ClearWay Débarras">
        <meta property="og:image" content="{% block og_image %}{{ absolute_url(asset('image/og-image.jpg')) }}{% endblock %}">
        <meta property="og:image:width" content="1200">
        <meta property="og:image:height" content="630">
        <meta name="twitter:card" content="summary_large_image">
        <meta name="twitter:title" content="{{ block('title') }}">
        <meta name="twitter:description" content="{{ block('meta_description') }}">
        <meta name="twitter:image" content="{{ block('og_image') }}">
        <meta name="geo.region" content="FR-35">
        <meta name="geo.placename" content="Vitré">
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🏠</text></svg>">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500;600&display=swap">
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
        {% block schema_org %}
        <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "LocalBusiness",
            "name": "ClearWay Débarras",
            "description": "Service professionnel de débarras maison, appartement, succession et Diogène.",
            "url": "{{ url('accueil') }}",
            "telephone": "+33123456789",
            "email": "contact@clearway.fr",
            "areaServed": {
                "@type": "AdministrativeArea",
                "name": "Ille-et-Vilaine, Bretagne"
            },
            "priceRange": "€€",
            "serviceType": ["Débarras maison", "Débarras appartement", "Débarras Diogène", "Débarras succession", "Débarras déménagement", "Débarras logement insalubre", "Débarras cave grenier"]
        }
        </script>
        {% endblock %}
        <style>
            :root {
                --accent: #ff5a1f;
                --accent-deep: #c2410c;
                --accent-soft: #fff1e8;
                --ink: #0a0a0b;
                --ink-2: #18181b;
                --text: #111827;
                --muted: #6b7280;
                --danger: #ef4444;
                --line: #e8e6e1;
                --paper: #faf8f4;
                --card: #f4f1ec;
                --bg: #ffffff;
                --radius: 20px;
                --radius-sm: 10px;
                --radius-full: 999px;
                --max: 1200px;
                --shadow-sm: 0 1px 3px rgba(0,0,0,0.04), 0 4px 12px rgba(0,0,0,0.03);
                --shadow-lg: 0 18px 50px rgba(0,0,0,0.08);
                --shadow-orange: 0 10px 28px rgba(255, 90, 31, 0.32);
            }
            * { box-sizing: border-box; margin: 0; padding: 0; }
            html { scroll-behavior: smooth; }
            body {
                font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
                background: var(--paper);
                color: var(--text);
                -webkit-font-smoothing: antialiased;
                line-height: 1.65;
                font-size: 16px;
                min-height: 100vh;
                display: flex;
                flex-direction: column;
                overflow-x: hidden;
                font-feature-settings: "ss01", "cv11";
            }
            body::before {
                content: "";
                position: fixed;
                inset: 0;
                pointer-events: none;
                z-index: 200;
                opacity: 0.035;
                mix-blend-mode: multiply;
                background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='180' height='180'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
            }
            a { color: inherit; text-decoration: none; }
            button { font-family: inherit; cursor: pointer; border: none; background: none; }
            .serif { font-family: 'Instrument Serif', serif; font-weight: 400; font-style: italic; letter-spacing: -0.01em; }
            .mono { font-family: 'JetBrains Mono', ui-monospace, monospace; }
            main { flex: 1; }
            .container { width: 100%; max-width: var(--max); margin: 0 auto; padding: 0 28px; }

            /* ── Navbar ── */
            .navbar {
                position: sticky;
                top: 0;
                z-index: 100;
                background: rgba(250, 248, 244, 0.78);
                backdrop-filter: blur(18px) saturate(140%);
                -webkit-backdrop-filter: blur(18px) saturate(140%);
                border-bottom: 1px solid rgba(0, 0, 0, 0.06);
            }
            .nav-inner {
                display: flex;
                align-items: center;
                justify-content: space-between;
                height: 72px;
            }
            .nav-logo {
                display: flex; align-items: center; gap: 10px;
                text-decoration: none; color: var(--ink);
                font-weight: 800; font-size: 20px; letter-spacing: -0.02em;
            }
            .logo-dot {
                width: 32px; height: 32px;
                background: var(--ink);
                border-radius: 10px;
                display: grid; place-items: center;
                color: #fff; font-size: 16px; font-weight: 900;
                position: relative; overflow: hidden;
            }
            .logo-dot::after {
                content: "";
                position: absolute;
                inset: 0;
                background: radial-gradient(circle at 30% 30%, var(--accent), transparent 60%);
                opacity: 0.85;
            }
            .logo-dot span { position: relative; z-index: 1; }
            .nav-links { display: flex; align-items: center; gap: 4px; }
            .nav-links a {
                color: var(--muted); text-decoration: none; font-weight: 500; font-size: 14px;
                padding: 8px 14px; border-radius: var(--radius-full); transition: all 0.15s;
            }
            .nav-links a:hover { color: var(--ink); background: rgba(0,0,0,0.05); }
            .nav-cta {
                background: var(--ink); color: #fff;
                padding: 11px 20px 11px 22px; border-radius: var(--radius-full);
                font-weight: 600; font-size: 14px;
                display: inline-flex; align-items: center; gap: 8px;
                transition: transform 0.18s, background 0.15s;
                margin-left: 8px; white-space: nowrap; text-decoration: none;
            }
            .nav-cta:hover { background: var(--accent); transform: translateY(-1px); }
            .nav-cta::after {
                content: "\2192"; font-size: 14px; transition: transform 0.2s;
            }
            .nav-cta:hover::after { transform: translateX(3px); }
            .nav-toggle {
                display: none; background: none; border: none;
                width: 40px; height: 40px; border-radius: 10px;
                place-items: center; cursor: pointer;
            }
            .nav-toggle span {
                width: 18px; height: 2px; background: var(--ink); position: relative;
                display: block;
            }
            .nav-toggle span::before,
            .nav-toggle span::after {
                content: ""; position: absolute; left: 0;
                width: 18px; height: 2px; background: var(--ink);
            }
            .nav-toggle span::before { top: -6px; }
            .nav-toggle span::after { top: 6px; }

            /* ── Floating buttons ── */
            .sticky-cta {
                position: fixed; bottom: 24px; right: 24px; z-index: 90;
                background: var(--ink); color: #fff;
                padding: 14px 20px 14px 14px; border-radius: var(--radius-full);
                text-decoration: none; font-weight: 600; font-size: 14px;
                box-shadow: 0 14px 36px rgba(0, 0, 0, 0.22);
                transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
                display: inline-flex; align-items: center; gap: 10px;
                border: 1px solid #27272a; white-space: nowrap;
            }
            .sticky-cta:hover {
                transform: translateY(-3px);
                box-shadow: 0 18px 44px rgba(0, 0, 0, 0.30);
                background: var(--accent); border-color: var(--accent);
            }
            .sticky-cta .pill-mini {
                width: 26px; height: 26px; border-radius: 50%; background: var(--accent);
                display: grid; place-items: center; flex-shrink: 0;
                transition: background 0.2s;
            }
            .sticky-cta:hover .pill-mini { background: white; }
            .sticky-cta .pill-mini::before {
                content: "\2192"; color: white; font-size: 13px; font-weight: 700;
            }
            .sticky-cta:hover .pill-mini::before { color: var(--accent); }
            .sticky-cta .mono-time {
                font-family: 'JetBrains Mono', monospace;
                font-size: 11px; color: #71717a; font-weight: 500;
            }
            .sticky-cta:hover .mono-time { color: rgba(255,255,255,0.85); }
            .whatsapp-btn {
                position: fixed; bottom: 24px; left: 24px; z-index: 90;
                width: 52px; height: 52px; background: #25d366; border-radius: 50%;
                display: grid; place-items: center;
                box-shadow: 0 8px 24px rgba(37, 211, 102, 0.40);
                transition: transform 0.2s; text-decoration: none; color: white;
            }
            .whatsapp-btn:hover { transform: scale(1.08); }
            .whatsapp-btn svg { width: 24px; height: 24px; }

            /* ── Modal ── */
            .modal-overlay {
                display: none; position: fixed; inset: 0;
                background: rgba(0,0,0,0.4); backdrop-filter: blur(4px);
                z-index: 100; align-items: center; justify-content: center;
            }
            .modal-overlay.open { display: flex; }
            .modal-box {
                background: var(--bg); border-radius: 20px;
                padding: 32px; max-width: 400px; width: 90%;
                position: relative; box-shadow: 0 24px 48px rgba(0,0,0,0.12);
            }
            .modal-box h3 { margin: 0 0 4px; font-size: 22px; font-weight: 800; }
            .modal-box p { color: var(--muted); font-size: 14px; margin: 0 0 20px; }
            .modal-close {
                position: absolute; top: 16px; right: 16px;
                background: var(--paper); border: none; width: 32px; height: 32px;
                border-radius: 50%; font-size: 16px; cursor: pointer; color: var(--muted);
                display: flex; align-items: center; justify-content: center;
            }
            .modal-close:hover { background: var(--line); }
            .modal-box .form-group { margin-bottom: 12px; }
            .modal-box .form-group input {
                width: 100%; padding: 12px 14px; border: 1px solid var(--line);
                border-radius: var(--radius-sm); font-size: 14px; font-family: inherit;
                transition: border-color 0.15s; background: var(--bg);
            }
            .modal-box .form-group input:focus { outline: none; border-color: var(--accent); }
            .modal-box .btn-submit {
                width: 100%; padding: 13px; background: var(--ink); color: #fff;
                border: none; border-radius: var(--radius-sm);
                font-weight: 700; font-size: 15px; cursor: pointer;
                margin-top: 4px; transition: opacity 0.15s; font-family: inherit;
            }
            .modal-box .btn-submit:hover { opacity: 0.9; }
            .modal-success { text-align: center; color: var(--accent-deep); font-weight: 600; padding: 20px 0; }

            /* ── Footer ── */
            .site-footer {
                background: var(--ink); color: white;
                padding: 80px 0 28px;
                border-top: 1px solid #1f1f23;
                font-size: 14px;
                margin-top: auto;
            }
            .footer-top {
                display: grid;
                grid-template-columns: 1.6fr 1fr 1fr 1fr;
                gap: 60px;
                padding-bottom: 80px;
            }
            .footer-brand-block { max-width: 360px; }
            .footer-brand {
                font-size: 36px; font-weight: 800; color: #fff;
                letter-spacing: -0.03em; margin-bottom: 16px;
                display: flex; align-items: center; gap: 10px;
            }
            .footer-brand .logo-dot { width: 38px; height: 38px; font-size: 18px; }
            .footer-tag {
                color: #a1a1aa; font-size: 15px;
                line-height: 1.6; margin-bottom: 28px;
            }
            .footer-contact {
                font-family: 'JetBrains Mono', monospace;
                font-size: 13px; color: #71717a; line-height: 1.8;
            }
            .footer-contact strong { color: white; font-weight: 500; }
            .footer-col h5 {
                font-family: 'JetBrains Mono', monospace;
                font-size: 11px; font-weight: 500;
                text-transform: uppercase; letter-spacing: 0.12em;
                margin-bottom: 22px; color: #71717a;
            }
            .footer-col ul { list-style: none; }
            .footer-col li { margin-bottom: 12px; }
            .footer-col a {
                color: #d4d4d8; font-size: 15px; transition: color 0.15s;
            }
            .footer-col a:hover { color: var(--accent); }
            .footer-mega {
                font-size: clamp(40px, 8vw, 140px);
                font-weight: 800; letter-spacing: -0.06em;
                line-height: 0.9; color: white;
                padding: 24px 0; text-align: center;
                border-top: 1px solid #27272a;
                border-bottom: 1px solid #27272a;
                margin-bottom: 20px; overflow: hidden; white-space: nowrap;
            }
            .footer-mega em {
                font-family: 'Instrument Serif', serif;
                font-weight: 400; font-style: italic; color: var(--accent);
            }
            .footer-bottom {
                padding-top: 18px; font-size: 13px; color: #52525b;
                display: flex; justify-content: space-between;
                flex-wrap: wrap; gap: 18px;
            }
            .footer-bottom .links { display: flex; gap: 18px; flex-wrap: wrap; }
            .footer-bottom a { color: #52525b; transition: color 0.15s; }
            .footer-bottom a:hover { color: #a1a1aa; }

            @media (max-width: 1024px) {
                .footer-top { grid-template-columns: 1fr 1fr 1fr; gap: 40px; }
                .footer-brand-block { grid-column: span 3; max-width: 100%; }
            }
            @media (max-width: 900px) {
                .footer-top { grid-template-columns: 1fr 1fr; gap: 40px; }
                .footer-brand-block { grid-column: span 2; }
            }
            @media (max-width: 480px) {
                .sticky-cta { bottom: 16px; right: 16px; padding: 12px 16px 12px 12px; font-size: 13px; }
                .whatsapp-btn { bottom: 16px; left: 16px; width: 46px; height: 46px; }
                .whatsapp-btn svg { width: 20px; height: 20px; }
            }
            @media (max-width: 640px) {
                .nav-toggle { display: grid; }
                .nav-links {
                    display: none; position: absolute; top: 100%;
                    left: 0; right: 0; background: rgba(250, 248, 244, 0.98);
                    backdrop-filter: blur(18px);
                    flex-direction: column; padding: 12px 20px; gap: 4px;
                    border-bottom: 1px solid rgba(0,0,0,0.06);
                    box-shadow: 0 8px 24px rgba(0,0,0,0.06);
                }
                .nav-links.open { display: flex; }
                .navbar .nav-inner { position: relative; }
                .sticky-cta .mono-time { display: none; }
                .footer-top { grid-template-columns: 1fr; }
                .footer-brand-block { grid-column: span 1; }
                .container { padding: 0 20px; }
            }
        </style>
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        <nav class="navbar">
            <div class="container nav-inner">
                <a href="{{ path('accueil') }}" class="nav-logo">
                    <span class="logo-dot"><span>C</span></span>
                    ClearWay
                </a>
                <button class="nav-toggle" onclick="document.querySelector('.nav-links').classList.toggle('open')" aria-label="Menu">
                    <span></span>
                </button>
                <div class="nav-links">
                    <a href="{{ path('services') }}">Services</a>
                    <a href="{{ path('blog') }}">Blog</a>
                    <a href="{{ path('contact') }}">Contact</a>
                </div>
                <a href="{{ path('estimation_formulaire') }}" class="nav-cta">Estimer en 2 min</a>
            </div>
        </nav>

        <main>
            {% block body %}{% endblock %}
        </main>

        {% block footer %}
        <footer class="site-footer">
            <div class="container">
                <div class="footer-top">
                    <div class="footer-brand-block">
                        <div class="footer-brand">
                            <span class="logo-dot"><span>C</span></span>
                            ClearWay
                        </div>
                        <p class="footer-tag">Service professionnel de débarras à Vitré et en Ille-et-Vilaine. Intervention sous 48h, devis gratuit, évacuation incluse.</p>
                        <div class="footer-contact">
                            <div><strong>02 99 00 00 00</strong></div>
                            <div>contact@clearway.fr</div>
                            <div>Lun-Sam &middot; 8h-18h</div>
                        </div>
                    </div>
                    <div class="footer-col">
                        <h5>Services</h5>
                        <ul>
                            <li><a href="{{ path('services_detail', {slug: 'succession'}) }}">Succession</a></li>
                            <li><a href="{{ path('services_detail', {slug: 'diogene'}) }}">Syndrome de Diogène</a></li>
                            <li><a href="{{ path('services_detail', {slug: 'demenagement'}) }}">Déménagement</a></li>
                            <li><a href="{{ path('services_detail', {slug: 'cave-grenier'}) }}">Cave &amp; grenier</a></li>
                            <li><a href="{{ path('services_detail', {slug: 'logement-insalubre'}) }}">Logement insalubre</a></li>
                            <li><a href="{{ path('services_detail', {slug: 'maison'}) }}">Maison complète</a></li>
                        </ul>
                    </div>
                    <div class="footer-col">
                        <h5>Zones</h5>
                        <ul>
                            <li><a href="{{ path('ville_page', {ville: 'vitre'}) }}">Vitré</a></li>
                            <li><a href="{{ path('ville_page', {ville: 'fougeres'}) }}">Fougères</a></li>
                            <li><a href="{{ path('ville_page', {ville: 'rennes'}) }}">Rennes</a></li>
                            <li><a href="{{ path('ville_page', {ville: 'laval'}) }}">Laval</a></li>
                            <li><a href="{{ path('ville_page', {ville: 'saint-malo'}) }}">Saint-Malo</a></li>
                        </ul>
                    </div>
                    <div class="footer-col">
                        <h5>Entreprise</h5>
                        <ul>
                            <li><a href="{{ path('qui_sommes_nous') }}">Qui sommes-nous</a></li>
                            <li><a href="{{ path('blog') }}">Blog</a></li>
                            <li><a href="{{ path('mentions_legales') }}">Mentions légales</a></li>
                        </ul>
                    </div>
                </div>
                <div class="footer-mega">On vide. Vous <em>soufflez.</em></div>
                <div class="footer-bottom">
                    <span>&copy; {{ "now"|date("Y") }} ClearWay — Tous droits réservés</span>
                    <div class="links">
                        <a href="{{ path('mentions_legales') }}">Mentions légales</a>
                        <a href="{{ path('qui_sommes_nous') }}">Qui sommes-nous</a>
                    </div>
                </div>
            </div>
        </footer>
        {% endblock %}

        {% block sticky_cta %}
            <a href="{{ path('estimation_formulaire') }}" class="sticky-cta">
                <span class="pill-mini"></span>
                <span>Estimer mon débarras</span>
                <span class="mono-time">2 min</span>
            </a>
        {% endblock %}

        <a href="https://wa.me/33123456789?text=Bonjour%2C%20je%20souhaite%20un%20devis%20pour%20un%20d%C3%A9barras."
           class="whatsapp-btn" target="_blank" rel="noopener" aria-label="WhatsApp">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.892a11.821 11.821 0 00-3.48-8.413Z"/></svg>
        </a>

        {% block modal_rappel %}
        <div class="modal-overlay" data-controller="rappel-modal" data-rappel-modal-target="overlay">
            <div class="modal-box">
                <button class="modal-close" data-action="rappel-modal#close">&times;</button>
                <h3>Rappel gratuit</h3>
                <p>Un conseiller vous rappelle en moins de 2h.</p>
                <form data-rappel-modal-target="form" data-action="submit->rappel-modal#submit">
                    <div class="form-group">
                        <input type="text" name="nom" placeholder="Votre nom" required data-rappel-modal-target="nom">
                    </div>
                    <div class="form-group">
                        <input type="tel" name="telephone" placeholder="06 12 34 56 78" required data-rappel-modal-target="telephone">
                    </div>
                    <button type="submit" class="btn-submit" data-rappel-modal-target="submitBtn">Me faire rappeler</button>
                </form>
                <div class="modal-success" style="display:none" data-rappel-modal-target="success">
                    Demande envoyée ! Nous vous rappelons rapidement.
                </div>
            </div>
        </div>
        {% endblock %}
    </body>
</html>
