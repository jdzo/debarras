<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <style>
        body { margin: 0; padding: 0; font-family: system-ui, sans-serif; background: #f8fafc; color: #0f172a; }
        .wrap { max-width: 560px; margin: 0 auto; padding: 32px 20px; }
        .alert { border-radius: 10px; padding: 16px; margin-bottom: 20px; }
        .alert-hot { background: #fee2e2; border: 1px solid #fca5a5; }
        .alert-hot h2 { color: #dc2626; margin: 0 0 4px; font-size: 18px; }
        .alert-warm { background: #fef9c3; border: 1px solid #fde68a; }
        .alert-warm h2 { color: #a16207; margin: 0 0 4px; font-size: 18px; }
        .alert-cold { background: #f1f5f9; border: 1px solid #e2e8f0; }
        .alert-cold h2 { color: #475569; margin: 0 0 4px; font-size: 18px; }
        .alert p { margin: 0; font-size: 14px; }
        .card { background: #fff; border-radius: 10px; padding: 20px; border: 1px solid #f1f5f9; }
        .row { display: flex; justify-content: space-between; padding: 6px 0; font-size: 13px; border-bottom: 1px solid #f8fafc; }
        .row:last-child { border-bottom: none; }
        .row .key { color: #6b7280; }
        .row .val { font-weight: 600; }
    </style>
</head>
<body>
<div class="wrap">
    <div class="alert alert-{{ score == 'Chaud' ? 'hot' : (score == 'Tiède' ? 'warm' : 'cold') }}">
        <h2>Nouveau lead {{ score }}</h2>
        <p>{{ nom }} via {{ type_capture }}</p>
    </div>
    <div class="card">
        <div class="row"><span class="key">Nom</span><span class="val">{{ nom }}</span></div>
        <div class="row"><span class="key">Téléphone</span><span class="val"><a href="tel:{{ telephone }}">{{ telephone }}</a></span></div>
        <div class="row"><span class="key">Score</span><span class="val">{{ score }}</span></div>
        <div class="row"><span class="key">Source</span><span class="val">{{ type_capture }}</span></div>
    </div>
</div>
</body>
</html>
