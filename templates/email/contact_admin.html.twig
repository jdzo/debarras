<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <style>
        body { margin: 0; padding: 0; font-family: system-ui, sans-serif; background: #f8fafc; color: #0f172a; }
        .wrap { max-width: 560px; margin: 0 auto; padding: 32px 20px; }
        .alert { background: #fef9c3; border: 1px solid #fde68a; border-radius: 10px; padding: 16px; margin-bottom: 20px; }
        .alert h2 { margin: 0 0 4px; font-size: 18px; color: #a16207; }
        .alert p { margin: 0; font-size: 14px; color: #92400e; }
        .card { background: #fff; border-radius: 10px; padding: 20px; margin-bottom: 16px; border: 1px solid #f1f5f9; }
        .card h3 { margin: 0 0 12px; font-size: 15px; }
        .row { display: flex; justify-content: space-between; padding: 6px 0; font-size: 13px; border-bottom: 1px solid #f8fafc; }
        .row:last-child { border-bottom: none; }
        .row .key { color: #6b7280; }
        .row .val { font-weight: 600; }
        .message-box { background: #f8fafc; border-radius: 8px; padding: 16px; font-size: 14px; line-height: 1.6; white-space: pre-wrap; }
    </style>
</head>
<body>
<div class="wrap">
    <div class="alert">
        <h2>Nouveau message de contact</h2>
        <p>{{ nom }} vous a envoyé un message via le formulaire de contact.</p>
    </div>

    <div class="card">
        <h3>Contact</h3>
        <div class="row">
            <span class="key">Nom</span>
            <span class="val">{{ nom }}</span>
        </div>
        <div class="row">
            <span class="key">Téléphone</span>
            <span class="val"><a href="tel:{{ telephone }}">{{ telephone }}</a></span>
        </div>
        {% if contact_email %}
        <div class="row">
            <span class="key">Email</span>
            <span class="val"><a href="mailto:{{ contact_email }}">{{ contact_email }}</a></span>
        </div>
        {% endif %}
    </div>

    {% if message %}
    <div class="card">
        <h3>Message</h3>
        <div class="message-box">{{ message }}</div>
    </div>
    {% endif %}
</div>
</body>
</html>
