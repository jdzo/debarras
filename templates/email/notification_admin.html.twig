<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <style>
        body { margin: 0; padding: 0; font-family: system-ui, sans-serif; background: #f8fafc; color: #0f172a; }
        .wrap { max-width: 560px; margin: 0 auto; padding: 32px 20px; }
        .alert { background: #dbeafe; border: 1px solid #93c5fd; border-radius: 10px; padding: 16px; margin-bottom: 20px; }
        .alert h2 { margin: 0 0 4px; font-size: 18px; color: #1d4ed8; }
        .alert p { margin: 0; font-size: 14px; color: #1e40af; }
        .card { background: #fff; border-radius: 10px; padding: 20px; margin-bottom: 16px; border: 1px solid #f1f5f9; }
        .card h3 { margin: 0 0 12px; font-size: 15px; }
        .row { display: flex; justify-content: space-between; padding: 6px 0; font-size: 13px; border-bottom: 1px solid #f8fafc; }
        .row:last-child { border-bottom: none; }
        .row .key { color: #6b7280; }
        .row .val { font-weight: 600; }
        .price { font-size: 22px; font-weight: 800; color: #16a34a; text-align: center; padding: 12px; background: #f0fdf4; border-radius: 8px; margin-bottom: 16px; }
    </style>
</head>
<body>
<div class="wrap">
    <div class="alert">
        <h2>Nouveau lead</h2>
        <p>{{ estimation.coordonnees.nom }} a demandé une estimation le {{ estimation.createdAt|date('d/m/Y à H:i') }}</p>
    </div>

    <div class="price">{{ estimation.fourchette }}</div>

    <div class="card">
        <h3>Contact</h3>
        <div class="row">
            <span class="key">Nom</span>
            <span class="val">{{ estimation.coordonnees.nom }}</span>
        </div>
        <div class="row">
            <span class="key">Téléphone</span>
            <span class="val"><a href="tel:{{ estimation.coordonnees.telephone }}">{{ estimation.coordonnees.telephone }}</a></span>
        </div>
        <div class="row">
            <span class="key">Email</span>
            <span class="val"><a href="mailto:{{ estimation.coordonnees.email }}">{{ estimation.coordonnees.email }}</a></span>
        </div>
        {% if estimation.coordonnees.adresse %}
        <div class="row">
            <span class="key">Adresse</span>
            <span class="val">{{ estimation.coordonnees.adresse }}{% if estimation.coordonnees.code_postal %}, {{ estimation.coordonnees.code_postal }}{% endif %}{% if estimation.coordonnees.ville %} {{ estimation.coordonnees.ville }}{% endif %}</span>
        </div>
        {% endif %}
    </div>

    <div class="card">
        <h3>Détails du bien</h3>
        <div class="row">
            <span class="key">Type</span>
            <span class="val">{{ estimation.typeDeBien }}</span>
        </div>
        <div class="row">
            <span class="key">Superficie</span>
            <span class="val">{{ estimation.superficie }}</span>
        </div>
        <div class="row">
            <span class="key">Encombrement</span>
            <span class="val">{{ estimation.encombrement }}</span>
        </div>
        <div class="row">
            <span class="key">Saleté</span>
            <span class="val">{{ estimation.salete }}</span>
        </div>
        <div class="row">
            <span class="key">Accessibilité</span>
            <span class="val">{{ estimation.accessibilite }}</span>
        </div>
    </div>

    {% if estimation.options.nettoyage or estimation.options.desinfection or estimation.options.demontage %}
    <div class="card">
        <h3>Options</h3>
        {% if estimation.options.nettoyage %}
        <div class="row"><span class="key">Nettoyage</span><span class="val">+150 €</span></div>
        {% endif %}
        {% if estimation.options.desinfection %}
        <div class="row"><span class="key">Désinfection</span><span class="val">+200 €</span></div>
        {% endif %}
        {% if estimation.options.demontage %}
        <div class="row"><span class="key">Démontage</span><span class="val">+100 €</span></div>
        {% endif %}
    </div>
    {% endif %}

    {% if estimation.commentaire %}
    <div class="card">
        <h3>Commentaire</h3>
        <p style="margin:0;font-size:14px;">{{ estimation.commentaire }}</p>
    </div>
    {% endif %}

    {% if estimation.photos is not empty %}
    <div class="card">
        <h3>Photos ({{ estimation.photos|length }})</h3>
        <p style="margin:0;font-size:13px;color:#6b7280;">{{ estimation.photos|length }} photo(s) jointe(s) à cette estimation.</p>
    </div>
    {% endif %}
</div>
</body>
</html>
