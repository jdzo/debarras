{% extends 'base.html.twig' %}

{% block title %}Estimation gratuite - ClearWay Débarras{% endblock %}
{% block meta_description %}Estimez le coût de votre débarras en 2 minutes. Formulaire simple, résultat immédiat, devis gratuit et sans engagement.{% endblock %}

{% block sticky_cta %}{% endblock %}

{% block stylesheets %}
<style>
    .form-wrap { max-width: 560px; margin: 48px auto; padding: 0 20px; }

    .form-header { text-align: center; margin-bottom: 36px; }
    .form-header h1 { font-size: 30px; font-weight: 900; margin: 0 0 8px; letter-spacing: -0.5px; }
    .form-header .subtitle { color: var(--muted); font-size: 15px; }
    .form-header .timer {
        display: inline-flex; align-items: center; gap: 6px;
        margin-top: 12px; padding: 6px 14px;
        background: var(--accent-light); color: var(--accent-dark);
        border-radius: var(--radius-full); font-size: 13px; font-weight: 600;
        border: 1px solid #fed7aa;
    }

    .progress-bar { background: #e4e4e7; border-radius: var(--radius-full); height: 4px; margin-bottom: 8px; overflow: hidden; }
    .progress-fill { height: 100%; background: var(--accent); border-radius: var(--radius-full); transition: width 0.3s ease; width: 25%; }
    .step-label { text-align: center; font-size: 12px; color: var(--muted); margin-bottom: 28px; font-weight: 500; }

    .step { display: none; }
    .step h2 { font-size: 20px; font-weight: 800; margin: 0 0 20px; text-align: center; letter-spacing: -0.3px; }

    .options-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 10px; }
    .option-card {
        background: var(--card); border: 2px solid #e4e4e7;
        border-radius: var(--radius); padding: 20px 14px; text-align: center;
        cursor: pointer; transition: all 0.15s;
    }
    .option-card:hover { border-color: #a1a1aa; }
    .option-card.selected { border-color: var(--accent); background: var(--accent-light); }
    .option-card input[type="radio"] { display: none; }
    .option-card .icon { font-size: 28px; margin-bottom: 8px; display: block; }
    .option-card .label { font-weight: 600; font-size: 14px; }

    .form-group { margin-bottom: 14px; }
    .form-group label { display: block; font-size: 13px; font-weight: 600; margin-bottom: 4px; color: var(--text); }
    .form-group input, .form-group textarea {
        width: 100%; padding: 12px 14px; border: 1px solid #e4e4e7;
        border-radius: var(--radius-sm); font-size: 15px; font-family: inherit;
        transition: border-color 0.15s;
    }
    .form-group input:focus, .form-group textarea:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.1); }
    .form-group textarea { resize: vertical; min-height: 80px; }

    .checkbox-group { display: flex; flex-direction: column; gap: 10px; }
    .checkbox-card {
        display: flex; align-items: center; gap: 12px;
        background: var(--card); border: 2px solid #e4e4e7;
        border-radius: var(--radius); padding: 14px 16px;
        cursor: pointer; transition: all 0.15s;
    }
    .checkbox-card:hover { border-color: #a1a1aa; }
    .checkbox-card.checked { border-color: var(--accent); background: var(--accent-light); }
    .checkbox-card input[type="checkbox"] { width: 18px; height: 18px; accent-color: var(--accent); cursor: pointer; }
    .checkbox-card .label { font-weight: 600; font-size: 14px; }
    .checkbox-card .desc { font-size: 12px; color: var(--muted); }

    .photo-upload { border: 2px dashed #e4e4e7; border-radius: var(--radius); padding: 24px; text-align: center; cursor: pointer; transition: border-color 0.15s; }
    .photo-upload:hover { border-color: #a1a1aa; }
    .photo-upload input[type="file"] { display: none; }
    .photo-upload .icon { font-size: 32px; margin-bottom: 8px; }
    .photo-upload .hint { font-size: 13px; color: var(--muted); }

    .nav-buttons {
        display: flex; justify-content: space-between; align-items: center;
        margin-top: 28px; padding-top: 20px; border-top: 1px solid #e4e4e7;
    }
    .btn {
        padding: 12px 28px; border-radius: var(--radius-full);
        font-weight: 600; font-size: 15px; border: none; cursor: pointer;
        transition: all 0.15s; font-family: inherit;
    }
    .btn:active { transform: scale(0.97); }
    .btn-prev { background: var(--bg); color: var(--text); border: 1px solid #e4e4e7; }
    .btn-prev:hover { border-color: #a1a1aa; }
    .btn-next { background: var(--text); color: #fff; }
    .btn-next:hover { opacity: 0.9; }
    .btn-submit { background: var(--text); color: #fff; display: none; }
    .btn-submit:hover { opacity: 0.9; }

    @keyframes shake { 0%, 100% { transform: translateX(0); } 25% { transform: translateX(-8px); } 75% { transform: translateX(8px); } }
    .shake { animation: shake 0.4s ease; }

    @media (max-width: 480px) {
        .options-grid { grid-template-columns: 1fr 1fr; }
        .form-wrap { margin: 24px auto; }
        .form-header h1 { font-size: 24px; }
    }
</style>
{% endblock %}

{% block body %}
<div class="form-wrap">
    <div class="form-header">
        <h1>Estimez votre débarras</h1>
        <p class="subtitle">Quelques questions pour recevoir votre estimation</p>
        <span class="timer"><span style="width:6px;height:6px;border-radius:50%;background:var(--accent);display:inline-block;"></span> 2 minutes</span>
    </div>

    <div class="progress-bar">
        <div class="progress-fill" data-form-stepper-target="progressFill"></div>
    </div>
    <div class="step-label" data-form-stepper-target="stepLabel">Étape 1 / 4 — Type de bien</div>

    <form method="post" action="{{ path('estimation_soumettre') }}" enctype="multipart/form-data"
          data-controller="form-stepper" data-turbo="false">
        <input type="hidden" name="_token" value="{{ csrf_token('estimation') }}">

        <div class="step" data-form-stepper-target="step">
            <h2>Quel type de bien ?</h2>
            <div class="options-grid" data-group="type_de_bien">
                {% set icons = {'maison': '🏠', 'appartement': '🏢', 'local_commercial': '🏪', 'cave_grenier': '📦', 'garage': '🚗'} %}
                {% for type in types_de_bien %}
                <label class="option-card" data-action="click->form-stepper#selectOption">
                    <input type="radio" name="type_de_bien" value="{{ type.value }}" required>
                    <span class="icon">{{ icons[type.value] ?? '🏠' }}</span>
                    <span class="label">{{ type.label() }}</span>
                </label>
                {% endfor %}
            </div>
        </div>

        <div class="step" data-form-stepper-target="step">
            <h2>Quelle superficie ?</h2>
            <div class="options-grid" data-group="superficie">
                {% set sup_icons = {'0_50': '🔹', '50_100': '🔸', '100_200': '🟠', '200_plus': '🔴'} %}
                {% for sup in superficies %}
                <label class="option-card" data-action="click->form-stepper#selectOption">
                    <input type="radio" name="superficie" value="{{ sup.value }}" required>
                    <span class="icon">{{ sup_icons[sup.value] ?? '📐' }}</span>
                    <span class="label">{{ sup.label() }}</span>
                </label>
                {% endfor %}
            </div>
        </div>

        <div class="step" data-form-stepper-target="step">
            <h2>Niveau d'encombrement ?</h2>
            <div class="options-grid" data-group="encombrement">
                {% set enc_icons = {'vide': '🟢', 'meuble_normal': '🟡', 'tres_encombre': '🔴'} %}
                {% for enc in niveaux_encombrement %}
                <label class="option-card" data-action="click->form-stepper#selectOption">
                    <input type="radio" name="encombrement" value="{{ enc.value }}" required>
                    <span class="icon">{{ enc_icons[enc.value] ?? '📦' }}</span>
                    <span class="label">{{ enc.label() }}</span>
                </label>
                {% endfor %}
            </div>
        </div>

        <div class="step" data-form-stepper-target="step">
            <h2>Niveau de saleté ?</h2>
            <div class="options-grid" data-group="salete">
                {% set sal_icons = {'propre': '✨', 'sale': '🧹', 'tres_sale': '🟠', 'diogene': '🔴'} %}
                {% for sal in niveaux_salete %}
                <label class="option-card" data-action="click->form-stepper#selectOption">
                    <input type="radio" name="salete" value="{{ sal.value }}" required>
                    <span class="icon">{{ sal_icons[sal.value] ?? '🧹' }}</span>
                    <span class="label">{{ sal.label() }}</span>
                </label>
                {% endfor %}
            </div>
        </div>

        <div class="step" data-form-stepper-target="step">
            <h2>Accessibilité du lieu ?</h2>
            <div class="options-grid" data-group="accessibilite">
                {% set acc_icons = {'rdc': '🏠', 'etage_avec_ascenseur': '🛗', 'etage_sans_ascenseur': '🪜'} %}
                {% for acc in accessibilites %}
                <label class="option-card" data-action="click->form-stepper#selectOption">
                    <input type="radio" name="accessibilite" value="{{ acc.value }}" required>
                    <span class="icon">{{ acc_icons[acc.value] ?? '🏠' }}</span>
                    <span class="label">{{ acc.label() }}</span>
                </label>
                {% endfor %}
            </div>
        </div>

        <div class="step" data-form-stepper-target="step">
            <h2>Options supplémentaires</h2>
            <p style="text-align:center;color:var(--muted);margin-bottom:20px;font-size:14px;">
                Sélectionnez les prestations souhaitées (facultatif)
            </p>
            <div class="checkbox-group">
                <label class="checkbox-card" onclick="this.classList.toggle('checked')">
                    <input type="checkbox" name="option_nettoyage" value="1">
                    <div>
                        <span class="label">🧽 Nettoyage après débarras</span>
                        <span class="desc">Nettoyage complet des pièces débarrassées</span>
                    </div>
                </label>
                <label class="checkbox-card" onclick="this.classList.toggle('checked')">
                    <input type="checkbox" name="option_desinfection" value="1">
                    <div>
                        <span class="label">🦠 Désinfection</span>
                        <span class="desc">Traitement désinfectant des surfaces</span>
                    </div>
                </label>
                <label class="checkbox-card" onclick="this.classList.toggle('checked')">
                    <input type="checkbox" name="option_demontage" value="1">
                    <div>
                        <span class="label">🔧 Démontage de meubles</span>
                        <span class="desc">Démontage des meubles volumineux</span>
                    </div>
                </label>
            </div>
        </div>

        <div class="step" data-form-stepper-target="step">
            <h2>Détails complémentaires</h2>
            <p style="text-align:center;color:var(--muted);margin-bottom:20px;font-size:14px;">
                Ces informations nous aident à affiner votre estimation (facultatif)
            </p>
            <div class="form-group">
                <label for="adresse">Adresse</label>
                <input type="text" id="adresse" name="adresse" placeholder="12 rue de la Paix">
            </div>
            <div class="form-group">
                <label for="ville">Ville</label>
                <input type="text" id="ville" name="ville" placeholder="Vitré">
            </div>
            <div class="form-group">
                <label for="commentaire">Commentaire</label>
                <textarea id="commentaire" name="commentaire" placeholder="Précisions sur le débarras, accès, contraintes..." maxlength="2000"></textarea>
            </div>
            <div class="form-group">
                <label>Photos (5 max)</label>
                <label class="photo-upload">
                    <input type="file" name="photos[]" multiple accept="image/*" id="photos">
                    <span class="icon">📷</span>
                    <div class="hint">Cliquez pour ajouter des photos</div>
                </label>
            </div>
        </div>

        <div class="step" data-form-stepper-target="step">
            <h2>Vos coordonnées</h2>
            <p style="text-align:center;color:var(--muted);margin-bottom:20px;font-size:14px;">
                Pour recevoir votre estimation personnalisée
            </p>
            <div class="form-group">
                <label for="nom">Nom</label>
                <input type="text" id="nom" name="nom" required placeholder="Votre nom complet">
            </div>
            <div class="form-group">
                <label for="telephone">Téléphone</label>
                <input type="tel" id="telephone" name="telephone" required placeholder="06 12 34 56 78">
            </div>
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" required placeholder="votre@email.com">
            </div>
            <div class="form-group">
                <label for="code_postal">Code postal</label>
                <input type="text" id="code_postal" name="code_postal" placeholder="35000">
            </div>
        </div>

        <div class="nav-buttons">
            <button type="button" class="btn btn-prev" style="display:none"
                    data-form-stepper-target="prevBtn" data-action="form-stepper#prev">Précédent</button>
            <div></div>
            <button type="button" class="btn btn-next"
                    data-form-stepper-target="nextBtn" data-action="form-stepper#next">Suivant →</button>
            <button type="submit" class="btn btn-submit"
                    data-form-stepper-target="submitBtn">Obtenir mon estimation →</button>
        </div>
    </form>
</div>
{% endblock %}
