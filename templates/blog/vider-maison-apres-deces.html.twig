{% extends 'base.html.twig' %}

{% block title %}Comment faire vider une maison après un décès : guide complet | ClearWay{% endblock %}
{% block meta_description %}Guide complet pour vider la maison d'un proche décédé : démarches légales, tri des affaires, choix du prestataire, coûts. Conseils pratiques étape par étape.{% endblock %}

{% block schema_org %}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "{{ article.titre }}",
    "description": "{{ article.description }}",
    "datePublished": "{{ article.date }}",
    "dateModified": "{{ article.date }}",
    "author": {
        "@type": "Organization",
        "name": "ClearWay Débarras"
    },
    "publisher": {
        "@type": "Organization",
        "name": "ClearWay Débarras",
        "url": "{{ url('accueil') }}"
    },
    "mainEntityOfPage": "{{ url('blog_article', {slug: slug}) }}"
}
</script>
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
        {
            "@type": "Question",
            "name": "Peut-on vider une maison avant la fin de la succession ?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Oui, à condition que tous les héritiers soient d'accord. Tant que la succession n'est pas réglée, les biens appartiennent à l'indivision. L'accord de chaque héritier est nécessaire avant de toucher à quoi que ce soit. En cas de désaccord, le notaire peut trancher."
            }
        },
        {
            "@type": "Question",
            "name": "Combien coûte le vidage complet d'une maison après décès ?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Le prix varie selon le volume, l'accessibilité et la localisation. Pour une maison de 3-4 pièces, comptez entre 800 et 2 500 €. Pour une grande maison avec dépendances (grenier, cave, garage), cela peut aller jusqu'à 4 000-5 000 €. La plupart des entreprises proposent un devis gratuit après visite."
            }
        },
        {
            "@type": "Question",
            "name": "Que faire des objets de valeur trouvés dans la maison ?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Les objets de valeur (bijoux, tableaux, meubles anciens, collections) doivent être inventoriés et partagés entre les héritiers selon les règles de la succession. Un commissaire-priseur peut estimer les pièces de valeur. Les entreprises de débarras sérieuses mettent systématiquement de côté tout objet potentiellement précieux."
            }
        }
    ]
}
</script>
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Accueil", "item": "{{ url('accueil') }}"},
        {"@type": "ListItem", "position": 2, "name": "Blog", "item": "{{ url('blog') }}"},
        {"@type": "ListItem", "position": 3, "name": "Vider une maison après un décès"}
    ]
}
</script>
{% endblock %}

