{% block body %}
<section class="article-hero">
    <div class="container">
        <div class="article-breadcrumb">
            <a href="{{ path('accueil') }}">Accueil</a> / <a href="{{ path('blog') }}">Blog</a> / Vider une maison après un décès
        </div>
