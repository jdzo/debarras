{% extends 'base.html.twig' %}

{% block title %}Qui sommes-nous — ClearWay | Débarras en Ille-et-Vilaine{% endblock %}
{% block meta_description %}Découvrez ClearWay, votre spécialiste du débarras à Vitré et en Ille-et-Vilaine. Une équipe professionnelle, réactive et respectueuse de votre situation.{% endblock %}

{% block stylesheets %}
<style>
    .about-wrap {
        max-width: 800px;
        margin: 0 auto;
        padding: 48px 20px;
    }
    .about-header {
        text-align: center;
        margin-bottom: 40px;
    }
    .about-header h1 {
        font-size: 32px;
        margin: 0 0 12px;
    }
    .about-header p {
        color: var(--muted);
        font-size: 18px;
        margin: 0;
    }
    .about-section {
        margin-bottom: 36px;
    }
    .about-section h2 {
        font-size: 22px;
        margin: 0 0 12px;
        color: var(--accent);
    }
    .about-section p {
        color: var(--muted);
        line-height: 1.7;
        margin: 0 0 12px;
    }
    .values-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 20px;
        margin-top: 20px;
    }
    .value-card {
        background: var(--card);
        border-radius: var(--radius);
        padding: 24px;
        text-align: center;
    }
    .value-card .value-icon {
        font-size: 32px;
        margin-bottom: 12px;
    }
    .value-card h3 {
        font-size: 17px;
        margin: 0 0 8px;
    }
    .value-card p {
        color: var(--muted);
        font-size: 14px;
        line-height: 1.6;
        margin: 0;
    }
    .about-cta {
        text-align: center;
        margin-top: 48px;
        padding: 32px;
        background: var(--card);
        border-radius: var(--radius);
    }
    .about-cta h2 {
        font-size: 22px;
        margin: 0 0 12px;
    }
    .about-cta p {
        color: var(--muted);
        margin: 0 0 20px;
    }
    .about-cta .btn {
        display: inline-block;
        background: var(--accent);
        color: #fff;
        padding: 12px 28px;
        border-radius: var(--radius);
        text-decoration: none;
        font-weight: 600;
        transition: opacity .2s;
    }
    .about-cta .btn:hover {
        opacity: .9;
    }
</style>
{% endblock %}

{% block body %}
<div class="about-wrap">
    <div class="about-header">
        <h1>Qui sommes-nous ?</h1>
        <p>Une équipe locale, engagée et à votre écoute</p>
    </div>

    <div class="about-section">
        <h2>Notre histoire</h2>
        <p>
            ClearWay est née d'un constat simple : le débarras est souvent vécu comme une épreuve,
            surtout lorsqu'il survient dans des moments difficiles — succession, séparation, syndrome
            de Diogène. Nous avons voulu créer un service humain, professionnel et transparent pour
            accompagner chaque situation avec respect.
        </p>
        <p>
            Basés à Vitré, nous intervenons sur toute l'Ille-et-Vilaine et les départements limitrophes :
            Rennes, Fougères, Laval, Saint-Malo et leurs alentours.
        </p>
    </div>

    <div class="about-section">
        <h2>Notre métier</h2>
        <p>
            Nous prenons en charge le débarras complet de tous types de biens : maisons, appartements,
            caves, greniers, garages, locaux professionnels. Chaque intervention inclut le tri, l'évacuation,
            le nettoyage et la valorisation des objets récupérables.
        </p>
        <p>
            Nous privilégions le recyclage et le don aux associations locales. Ce qui ne peut être
            réutilisé est acheminé vers les filières de traitement agréées, dans le respect de
            l'environnement.
        </p>
    </div>

    <div class="about-section">
        <h2>Nos valeurs</h2>
        <div class="values-grid">
            <div class="value-card">
                <div class="value-icon">&#9203;</div>
                <h3>Réactivité</h3>
                <p>Devis sous 24h, intervention rapide adaptée à votre planning.</p>
            </div>
            <div class="value-card">
                <div class="value-icon">&#128101;</div>
                <h3>Respect</h3>
                <p>Écoute et discrétion, quelle que soit votre situation personnelle.</p>
            </div>
            <div class="value-card">
                <div class="value-icon">&#9852;</div>
                <h3>Éco-responsabilité</h3>
                <p>Tri systématique, recyclage et don pour limiter les déchets.</p>
            </div>
            <div class="value-card">
                <div class="value-icon">&#128176;</div>
                <h3>Transparence</h3>
                <p>Prix clairs, sans surprise. Estimation gratuite en ligne.</p>
            </div>
        </div>
    </div>

    <div class="about-section">
        <h2>Notre zone d'intervention</h2>
        <p>
            Nous intervenons principalement en Ille-et-Vilaine (35) et Mayenne (53) :
            Vitré, Fougères, Rennes, Laval, Saint-Malo et toutes les communes environnantes
            dans un rayon de 50 km.
        </p>
    </div>

    <div class="about-cta">
        <h2>Besoin d'un débarras ?</h2>
        <p>Obtenez une estimation gratuite en 2 minutes, sans engagement.</p>
        <a href="{{ path('estimation_formulaire') }}" class="btn">Estimer mon débarras</a>
    </div>
</div>
{% endblock %}
