{% extends 'base.html.twig' %}

{% block title %}Débarras maison Vitré & Ille-et-Vilaine — Estimation gratuite en 2 min | ClearWay{% endblock %}
{% block meta_description %}Débarras professionnel à Vitré et en Ille-et-Vilaine. Succession, Diogène, déménagement, cave, logement insalubre. Estimation gratuite en 2 min, intervention sous 48h.{% endblock %}

{% block schema_org %}
{{ parent() }}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
        {
            "@type": "Question",
            "name": "Combien coûte un débarras de maison à Vitré ?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Le prix d'un débarras à Vitré dépend du volume à évacuer et du type de bien. Pour une maison complète, comptez entre 800 et 3 000 €. Pour une cave ou un grenier, entre 200 et 1 000 €. Notre estimation en ligne vous donne un premier prix en 2 minutes."
            }
        },
        {
            "@type": "Question",
            "name": "Sous quel délai intervenez-vous à Vitré ?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Nous intervenons sous 48h à Vitré et dans un rayon de 50 km (Châteaubourg, Fougères, La Guerche-de-Bretagne, Rennes). En cas d'urgence, une intervention le jour même peut être organisée."
            }
        },
        {
            "@type": "Question",
            "name": "Le devis est-il gratuit ?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Oui, l'estimation en ligne est gratuite et sans engagement. Vous obtenez un premier prix en 2 minutes. Un conseiller vous rappelle ensuite pour affiner le devis et planifier l'intervention."
            }
        }
    ]
}
</script>
{% endblock %}

{% block stylesheets %}
<style>
    /* ── Hero ── */
    .hero {
        position: relative;
        padding: 80px 0 0;
        overflow: hidden;
    }
    .hero::before {
        content: "";
        position: absolute;
        top: 30%; left: 50%;
        width: 1100px; height: 1100px;
        transform: translate(-50%, -50%);
        background: radial-gradient(circle, rgba(255, 90, 31, 0.10), transparent 55%);
        pointer-events: none; z-index: 0;
    }
    .hero-inner { position: relative; z-index: 1; }
    .hero-head {
        text-align: center;
        max-width: 920px;
        margin: 0 auto;
    }
    .eyebrow {
        display: inline-flex; align-items: center; gap: 10px;
        background: white; border: 1px solid var(--line);
        padding: 7px 16px 7px 12px; border-radius: var(--radius-full);
        font-size: 13px; font-weight: 500;
        margin-bottom: 32px; box-shadow: var(--shadow-sm); white-space: nowrap;
    }
    .eyebrow strong { font-weight: 600; color: var(--ink); }
    .eyebrow .sep { color: var(--line); }
    .eyebrow-dot {
        width: 8px; height: 8px; background: #16a34a;
        border-radius: 50%; position: relative; animation: pulse 2s infinite;
    }
    @keyframes pulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(22, 163, 74, 0.5); }
        50% { box-shadow: 0 0 0 6px rgba(22, 163, 74, 0); }
    }
    .hero h1 {
        font-size: clamp(48px, 8.5vw, 116px);
        font-weight: 800; line-height: 0.94;
        letter-spacing: -0.045em; margin-bottom: 28px; color: var(--ink);
    }
    .hero h1 .l1, .hero h1 .l2 { display: block; }
    .hero h1 em {
        font-family: 'Instrument Serif', serif;
        font-weight: 400; font-style: italic;
        letter-spacing: -0.02em; color: var(--accent);
    }
    .hero .lead {
        font-size: 20px; color: var(--muted);
        max-width: 540px; margin: 0 auto 40px; line-height: 1.55;
    }
    .hero .lead strong { color: var(--ink); font-weight: 600; }
    .hero-ctas {
        display: flex; gap: 12px;
        justify-content: center; flex-wrap: wrap; margin-bottom: 24px;
    }
    .btn-hero {
        display: inline-flex; align-items: center; justify-content: center;
        gap: 10px; padding: 16px 30px; border-radius: var(--radius-full);
        font-size: 16px; font-weight: 600;
        transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.15s;
        border: 1px solid transparent; letter-spacing: -0.01em; white-space: nowrap;
    }
    .btn-hero.primary {
        background: var(--ink); color: white;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18), inset 0 1px 0 rgba(255,255,255,0.1);
    }
    .btn-hero.primary:hover {
        transform: translateY(-2px); background: var(--accent);
        box-shadow: var(--shadow-orange);
    }
    .btn-hero.primary::after {
        content: "\2192"; font-size: 17px; transition: transform 0.2s;
    }
    .btn-hero.primary:hover::after { transform: translateX(4px); }
    .btn-hero.secondary {
        background: transparent; border-color: rgba(0,0,0,0.15); color: var(--ink);
    }
    .btn-hero.secondary:hover {
        transform: translateY(-2px); border-color: var(--ink); background: white;
    }
    .reassure-row {
        display: inline-flex; align-items: center; gap: 14px;
        font-size: 13px; color: var(--muted);
        flex-wrap: wrap; justify-content: center; margin-bottom: 64px;
    }
    .reassure-row span { display: inline-flex; align-items: center; gap: 6px; }
    .reassure-row .check {
        width: 14px; height: 14px; border-radius: 50%; background: var(--accent); color: white;
        font-size: 9px; display: grid; place-items: center; font-weight: 800;
    }
    .reassure-row .dotsep { width: 3px; height: 3px; background: #d1d5db; border-radius: 50%; }

    /* Hero avant/après */
    .hero-frame {
        position: relative; margin: 0 auto; max-width: 1100px; padding: 0 28px;
    }
    .ba-grid {
        display: grid; grid-template-columns: 1fr 1fr;
        grid-template-rows: 480px; gap: 14px;
    }
    .ba-card {
        border-radius: 24px 24px 0 0; overflow: hidden;
        position: relative;
    }
    .ba-card img {
        position: absolute; inset: 0;
        width: 100%; height: 100%; object-fit: cover;
    }
    .ba-tag { z-index: 1; }
    .ba-tag {
        position: absolute; top: 16px; left: 16px;
        background: rgba(10, 10, 11, 0.88); color: white;
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px; font-weight: 600;
        padding: 6px 11px; border-radius: 6px;
        letter-spacing: 0.05em; text-transform: uppercase;
    }
    .ba-stat {
        position: absolute; bottom: 22px; left: 22px; right: 22px;
        display: flex; justify-content: space-between; align-items: end; color: var(--ink);
    }
    .ba-stat .big {
        font-size: 56px; font-weight: 800; letter-spacing: -0.04em; line-height: 0.9;
    }
    .ba-stat .lbl {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em;
        color: var(--ink-2); opacity: 0.7; max-width: 110px; text-align: right; line-height: 1.4;
    }
    .ba-card.after .ba-stat .big { color: var(--accent-deep); }

    /* ── Marquee ── */
    .marquee {
        background: var(--ink); color: white;
        padding: 18px 0;
        border-top: 1px solid #1f1f23; border-bottom: 1px solid #1f1f23;
        margin-top: -1px;
    }
    .marquee-track {
        display: flex; justify-content: center; gap: 56px; white-space: nowrap;
        align-items: center;
    }
    .marquee-item {
        font-size: 28px; font-weight: 700; letter-spacing: -0.02em;
        display: inline-flex; align-items: center; gap: 56px;
    }
    .marquee-item .star {
        color: var(--accent); font-size: 22px;
        font-family: 'Instrument Serif', serif; font-style: italic;
    }

    /* ── Proof bar ── */
    .proof-bar { background: var(--ink); color: white; }
    .proof-grid {
        display: grid; grid-template-columns: repeat(4, 1fr);
        max-width: 1200px; margin: 0 auto;
    }
    .proof-item {
        padding: 40px 24px; border-right: 1px solid #1f1f23;
    }
    .proof-item:last-child { border-right: none; }
    .proof-num {
        font-size: 15px; font-weight: 700;
        letter-spacing: -0.01em; line-height: 1.3;
        color: white; margin-bottom: 6px;
    }
    .proof-label {
        font-size: 13px; color: #a1a1aa; font-weight: 500; line-height: 1.5;
    }

    /* ── Section base ── */
    section.block { padding: 120px 0; position: relative; }
    .section-head { margin-bottom: 64px; max-width: 720px; }
    .section-head.center { text-align: center; margin-left: auto; margin-right: auto; }
    .section-head.center .section-sub { margin-left: auto; margin-right: auto; }
    .tag {
        font-family: 'JetBrains Mono', monospace;
        font-size: 12px; font-weight: 500;
        letter-spacing: 0.12em; color: var(--accent);
        margin-bottom: 20px; display: inline-flex; align-items: center; gap: 8px;
    }
    .tag::before { content: ""; width: 24px; height: 1px; background: var(--accent); }
    .section-title {
        font-size: clamp(36px, 5.2vw, 64px);
        font-weight: 800; letter-spacing: -0.035em;
        line-height: 1.0; margin-bottom: 20px; color: var(--ink);
    }
    .section-title em {
        font-family: 'Instrument Serif', serif;
        font-weight: 400; font-style: italic;
        color: var(--accent); letter-spacing: -0.02em;
    }
    .section-sub {
        font-size: 19px; color: var(--muted); line-height: 1.55; max-width: 580px;
    }

    /* ── Bento services ── */
    .bento {
        display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px;
    }
    .bento-card {
        background: var(--bg); border: 1px solid var(--line);
        border-radius: 20px; padding: 32px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex; flex-direction: column;
        min-height: 280px; position: relative; overflow: hidden;
        text-decoration: none; color: inherit;
    }
    .bento-card:hover {
        border-color: rgba(0,0,0,0.18); transform: translateY(-4px);
        box-shadow: var(--shadow-lg);
    }
    .bento-card.feature {
        grid-column: span 2; background: var(--ink);
        color: white; border-color: #1f1f23; min-height: 320px;
    }
    .bento-card.feature::before {
        content: ""; position: absolute; top: -50%; right: -20%;
        width: 60%; height: 200%;
        background: radial-gradient(circle, rgba(255, 90, 31, 0.15), transparent 60%);
        pointer-events: none;
    }
    .bento-card.feature:hover { border-color: rgba(255, 90, 31, 0.4); }
    .bento-num {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px; color: var(--muted);
        letter-spacing: 0.08em; margin-bottom: 28px;
    }
    .bento-card.feature .bento-num { color: #71717a; }
    .bento-icon {
        width: 56px; height: 56px; border-radius: 14px;
        background: var(--accent-soft); display: grid; place-items: center;
        margin-bottom: 24px; color: var(--accent);
    }
    .bento-card.feature .bento-icon {
        background: rgba(255, 90, 31, 0.15); color: var(--accent);
    }
    .bento-icon svg { width: 26px; height: 26px; stroke-width: 1.6; }
    .bento-card h3 {
        font-size: 22px; font-weight: 700; letter-spacing: -0.02em;
        margin-bottom: 12px; line-height: 1.2; color: var(--ink);
    }
    .bento-card.feature h3 {
        font-size: 30px; color: white; max-width: 80%;
    }
    .bento-card.feature h3 em {
        font-family: 'Instrument Serif', serif;
        font-weight: 400; font-style: italic; color: var(--accent);
    }
    .bento-card p {
        font-size: 15px; color: var(--muted); line-height: 1.6;
        margin-bottom: 24px; flex-grow: 1;
    }
    .bento-card.feature p { color: #d4d4d8; max-width: 70%; font-size: 16px; }
    .bento-link {
        color: var(--ink); font-size: 14px; font-weight: 600;
        align-self: flex-start; display: inline-flex; align-items: center; gap: 8px;
        border-bottom: 1px solid transparent; padding-bottom: 2px; transition: all 0.2s;
    }
    .bento-link:hover { color: var(--accent); border-color: var(--accent); }
    .bento-card.feature .bento-link { color: white; }
    .bento-card.feature .bento-link:hover { color: var(--accent); }

    /* ── Steps ── */
    .steps-section {
        background: var(--ink); color: white;
        border-radius: 32px; margin: 0 28px;
    }
    .steps-section .inner-pad { padding: 100px 0; }
    .steps-section .tag { color: var(--accent); }
    .steps-section .tag::before { background: var(--accent); }
    .steps-section .section-title { color: white; }
    .steps-section .section-sub { color: #a1a1aa; }
    .steps-list { border-top: 1px solid #27272a; }
    .step-row {
        display: grid; grid-template-columns: 80px 1fr 1.4fr;
        gap: 32px; padding: 36px 0; border-bottom: 1px solid #27272a;
        align-items: start; transition: background 0.2s;
    }
    .step-row:hover { background: rgba(255,255,255,0.01); }
    .step-num {
        font-family: 'JetBrains Mono', monospace;
        font-size: 14px; color: var(--accent); letter-spacing: 0.05em; padding-top: 6px;
    }
    .step-row h4 {
        font-size: 30px; font-weight: 700; letter-spacing: -0.025em;
        line-height: 1.1; color: white;
    }
    .step-row h4 em {
        font-family: 'Instrument Serif', serif;
        font-weight: 400; font-style: italic; color: var(--accent);
    }
    .step-row p {
        font-size: 16px; color: #a1a1aa; line-height: 1.65; padding-top: 8px;
    }

    /* ── Testimonials ── */
    .testimonials {
        display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px;
        padding-bottom: 28px;
    }
    .testimonial {
        background: var(--bg); border: 1px solid var(--line);
        border-radius: 20px; padding: 32px;
        display: flex; flex-direction: column; transition: all 0.25s;
    }
    .testimonial:hover {
        transform: translateY(-3px); box-shadow: var(--shadow-lg);
        border-color: rgba(0,0,0,0.12);
    }
    .testimonial:nth-child(2) { transform: translateY(28px); }
    .testimonial:nth-child(2):hover { transform: translateY(25px); }
    .stars {
        color: var(--accent); font-size: 16px;
        letter-spacing: 4px; margin-bottom: 18px;
    }
    .quote {
        font-family: 'Instrument Serif', serif;
        font-size: 24px; font-weight: 400; line-height: 1.3;
        letter-spacing: -0.01em; color: var(--ink);
        margin-bottom: 28px; flex-grow: 1;
    }
    .author {
        display: flex; align-items: center; gap: 12px;
        padding-top: 20px; border-top: 1px solid var(--line);
    }
    .avatar {
        width: 38px; height: 38px; border-radius: 50%;
        background: var(--accent-soft); color: var(--accent-deep);
        font-weight: 700; font-size: 13px; display: grid;
        place-items: center; flex-shrink: 0;
    }
    .author-name { font-size: 14px; font-weight: 600; line-height: 1.3; }
    .author-city { font-size: 13px; color: var(--muted); line-height: 1.3; }

    /* ── Zone ── */
    .zone-section { text-align: center; }
    .zone-circle {
        position: relative; margin: 64px auto 0;
        max-width: 640px; aspect-ratio: 1;
    }
    .zone-circle::before, .zone-circle::after {
        content: ""; position: absolute; inset: 0;
        border: 1px dashed rgba(0,0,0,0.12); border-radius: 50%;
    }
    .zone-circle::after {
        inset: 18%; border-style: dashed; border-color: rgba(255, 90, 31, 0.25);
    }
    .zone-center {
        position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
        background: var(--accent); color: white;
        padding: 14px 24px; border-radius: var(--radius-full);
        font-weight: 700; font-size: 16px; letter-spacing: -0.01em;
        box-shadow: var(--shadow-orange); display: inline-flex;
        align-items: center; gap: 8px; z-index: 2;
    }
    .zone-center::before { content: "\1F4CD"; font-size: 14px; }
    .city-pin {
        position: absolute; background: white; border: 1px solid var(--line);
        padding: 10px 18px; border-radius: var(--radius-full);
        font-size: 14px; font-weight: 600; box-shadow: var(--shadow-sm);
        transition: all 0.2s; white-space: nowrap; text-decoration: none; color: inherit;
    }
    .city-pin:hover { border-color: var(--accent); color: var(--accent); }
    .city-pin .km {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px; color: var(--muted); margin-left: 8px; font-weight: 500;
    }
    .city-pin:hover .km { color: var(--accent); opacity: 0.7; }
    .city-pin.c1 { top: 4%; left: 50%; transform: translate(-50%, 0); }
    .city-pin.c1:hover { transform: translate(-50%, 0) scale(1.05); }
    .city-pin.c2 { top: 22%; right: 4%; }
    .city-pin.c2:hover { transform: scale(1.05); }
    .city-pin.c3 { top: 50%; right: -2%; transform: translateY(-50%); }
    .city-pin.c3:hover { transform: translateY(-50%) scale(1.05); }
    .city-pin.c4 { bottom: 22%; right: 6%; }
    .city-pin.c4:hover { transform: scale(1.05); }
    .city-pin.c5 { bottom: 4%; left: 50%; transform: translate(-50%, 0); }
    .city-pin.c5:hover { transform: translate(-50%, 0) scale(1.05); }
    .city-pin.c6 { bottom: 22%; left: 6%; }
    .city-pin.c6:hover { transform: scale(1.05); }
    .city-pin.c7 { top: 50%; left: -2%; transform: translateY(-50%); }
    .city-pin.c7:hover { transform: translateY(-50%) scale(1.05); }
    .city-pin.c8 { top: 22%; left: 4%; }
    .city-pin.c8:hover { transform: scale(1.05); }
    .zone-fallback {
        display: none; flex-wrap: wrap; justify-content: center;
        gap: 10px; margin: 48px auto 0; max-width: 760px;
    }
    .zone-chip {
        background: white; border: 1px solid var(--line);
        padding: 10px 20px; border-radius: var(--radius-full);
        font-size: 14px; font-weight: 600; text-decoration: none; color: inherit;
        transition: all 0.15s;
    }
    .zone-chip:hover { border-color: var(--accent); color: var(--accent); }

    /* ── FAQ ── */
    .faq-grid {
        display: grid; grid-template-columns: 1fr 1.5fr; gap: 80px; align-items: start;
    }
    .faq-aside { position: sticky; top: 100px; }
    .faq-aside .section-title { margin-bottom: 24px; }
    .faq-aside .help-card {
        background: white; border: 1px solid var(--line);
        border-radius: 20px; padding: 24px; margin-top: 32px;
    }
    .faq-aside .help-card h5 {
        font-size: 15px; font-weight: 700; margin-bottom: 6px; letter-spacing: -0.01em;
    }
    .faq-aside .help-card p {
        font-size: 14px; color: var(--muted); margin-bottom: 16px;
    }
    .faq-aside .help-card a {
        font-size: 14px; font-weight: 600; color: var(--accent);
        display: inline-flex; align-items: center; gap: 6px;
    }
    .faq details { border-bottom: 1px solid var(--line); padding: 4px 0; }
    .faq details:first-child { border-top: 1px solid var(--line); }
    .faq summary {
        display: flex; justify-content: space-between; align-items: center;
        padding: 28px 0; font-size: 20px; font-weight: 600;
        letter-spacing: -0.015em; cursor: pointer; list-style: none;
        gap: 16px; color: var(--ink); transition: color 0.15s;
    }
    .faq summary:hover { color: var(--accent); }
    .faq summary::-webkit-details-marker { display: none; }
    .faq summary::after {
        content: ""; width: 24px; height: 24px; border-radius: 50%;
        border: 1.5px solid currentColor;
        background-image: linear-gradient(currentColor, currentColor), linear-gradient(currentColor, currentColor);
        background-size: 10px 1.5px, 1.5px 10px;
        background-position: center; background-repeat: no-repeat;
        transition: transform 0.25s ease; flex-shrink: 0;
    }
    .faq details[open] summary::after {
        transform: rotate(45deg); background-size: 10px 1.5px, 0 0;
    }
    .faq .answer {
        font-size: 16px; color: var(--muted); line-height: 1.7;
        padding-bottom: 28px; padding-right: 40px;
    }

    /* ── CTA final ── */
    .cta-section { padding: 0 0 120px; }
    .cta-final {
        background: var(--ink); border-radius: 28px;
        padding: 96px 72px; position: relative;
        overflow: hidden; color: white;
    }
    .cta-final::before {
        content: ""; position: absolute;
        width: 600px; height: 600px;
        background: radial-gradient(circle, rgba(255, 90, 31, 0.18), transparent 60%);
        top: -250px; right: -150px; pointer-events: none;
    }
    .cta-final::after {
        content: ""; position: absolute;
        width: 480px; height: 480px;
        background: radial-gradient(circle, rgba(255, 90, 31, 0.10), transparent 65%);
        bottom: -200px; left: -120px; pointer-events: none;
    }
    .cta-final-inner {
        position: relative; z-index: 1;
        display: grid; grid-template-columns: 1.4fr 1fr;
        gap: 60px; align-items: center;
    }
    .cta-final h2 {
        font-size: clamp(40px, 5.5vw, 72px);
        font-weight: 800; letter-spacing: -0.04em;
        line-height: 0.98; margin-bottom: 20px;
    }
    .cta-final h2 em {
        font-family: 'Instrument Serif', serif;
        font-weight: 400; font-style: italic; color: var(--accent);
    }
    .cta-final .tag { color: var(--accent); margin-bottom: 24px; }
    .cta-final .tag::before { background: var(--accent); }
    .cta-final p {
        font-size: 18px; color: #a1a1aa; max-width: 460px; margin-bottom: 0;
    }
    .cta-left .btn-cta {
        display: inline-flex; align-items: center; gap: 10px;
        background: var(--accent); color: white;
        padding: 20px 36px; border-radius: var(--radius-full);
        font-size: 17px; font-weight: 700;
        box-shadow: var(--shadow-orange); text-decoration: none;
        transition: all 0.2s; margin-top: 32px;
    }
    .cta-left .btn-cta::after { content: "\2192"; }
    .cta-left .btn-cta:hover { background: white; color: var(--ink); }
    .cta-reassurance {
        margin-top: 18px; font-size: 13px; color: #71717a;
